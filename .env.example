# ===========================================
# JUNIOR - AI Legal Assistant Configuration
# ===========================================

# ============ MULTI-MODEL ARCHITECTURE ============
# Each task uses a specialized model for best performance

# Groq API (for fast inference - DeepSeek-R1, Qwen, Llama)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=

# Perplexity AI (Sonar-Pro) - long context + online search
# Get your key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Google AI (for Gemini 1.5 Flash - long context)
# Get your free key at: https://ai.google.dev/
GOOGLE_API_KEY=

# Hugging Face (optional alternative LLM / IndicTrans2 translation)
# Get your free key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ============ DATABASE ============
# Supabase Configuration (for document storage and vector search)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# ============ APPLICATION ============
# Application Settings
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me

# Server Configuration
HOST=0.0.0.0
PORT=8000

# ============ SPECIALIZED MODEL SETTINGS ============
# Researcher: Long-context research + online search (Perplexity Sonar-Pro)
RESEARCHER_MODEL=sonar-pro
RESEARCHER_PROVIDER=perplexity

# Critic: Fast reasoning (Llama 3.3 70B on Groq)
CRITIC_MODEL=llama-3.3-70b-versatile
CRITIC_PROVIDER=groq

# Writer: Best instruction following (Llama 3.3 70B on Groq)
WRITER_MODEL=llama-3.3-70b-versatile
WRITER_PROVIDER=groq

# Chat: Conversational AI (Perplexity Sonar-Pro)
CHAT_MODEL=sonar-pro
CHAT_PROVIDER=perplexity

# Legacy default (kept for backward compatibility)
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile
REASONING_MODEL=llama-3.3-70b-versatile

# Embeddings: Multilingual + Hybrid search (bge-m3)
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# If your network blocks huggingface.co model downloads, keep this false.
# Embeddings will fall back to deterministic local embeddings (lower quality).
ALLOW_HF_MODEL_DOWNLOADS=false

# Manual ingestion (RAG training) settings
# NOTE: Ingestion is catalog-only by default (no arbitrary URL downloads).
MANUALS_DOWNLOAD_DIR=uploads/manuals
MANUALS_MAX_BYTES=50000000
MANUALS_ALLOW_URL_INGEST=false
# Optional allowlist if URL ingest is enabled (comma-separated domains)
MANUALS_ALLOWLIST_DOMAINS=

# Voice-to-Brief
WHISPER_MODEL_SIZE=base
# Max upload size for /api/v1/audio/transcribe (bytes)
AUDIO_MAX_BYTES=25000000

# Privacy Settings
ENABLE_PII_REDACTION=true
WATERMARK_DRAFTS=true

# Translation Settings
DEFAULT_SOURCE_LANG=en
SUPPORTED_LANGUAGES=en,hi,mr,ta,te,bn,gu,kn,ml,pa
